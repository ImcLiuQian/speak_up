# Leave empty in production when Nginx proxies /api and /ws on the same domain.
# Local dev falls back to http://127.0.0.1:8000.
NEXT_PUBLIC_API_BASE_URL=
# Optional. When set, the footer Discord page opens this invite/community URL directly.
NEXT_PUBLIC_DISCORD_URL=
DASHSCOPE_API_KEY=sk-xxx

# Account database for login sessions, paid plan state, and daily quota.
SPEAK_UP_AUTH_DATA_DIR=output/auth_data
SPEAK_UP_AUTH_DB_PATH=output/auth_data/auth.sqlite3
# Required JSON array for the internal beta account pool.
# SPEAK_UP_INTERNAL_ACCOUNTS=[{"account":"account-id","password":"password","displayName":"内测用户"}]
SPEAK_UP_INTERNAL_ACCOUNTS=
SPEAK_UP_ALLOWED_ORIGINS=https://speakupcoach.cn,https://www.speakupcoach.cn
SPEAK_UP_WEBSOCKET_TOKEN_IN_QUERY=false

# Replay media storage. Use "local" for development, "oss" for Aliyun OSS.
SPEAK_UP_STORAGE_DRIVER=local
SPEAK_UP_OSS_BUCKET=
SPEAK_UP_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
SPEAK_UP_OSS_ACCESS_KEY_ID=
SPEAK_UP_OSS_ACCESS_KEY_SECRET=
SPEAK_UP_OSS_PUBLIC_BASE_URL=
SPEAK_UP_OSS_PREFIX=speak-up

# Aliyun realtime WebSocket stability
# 0 disables the client's keepalive ping; active audio traffic is still sent normally.
ALIYUN_WS_PING_INTERVAL_SECONDS=0
ALIYUN_WS_PING_TIMEOUT_SECONDS=30

# ASR
ALIYUN_REALTIME_ASR_MODEL=qwen3-asr-flash-realtime
ALIYUN_REALTIME_ASR_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ALIYUN_REALTIME_ASR_SILENCE_DURATION_MS=1200

# Live coach
ALIYUN_OMNI_COACH_MODEL=qwen3.5-omni-flash-realtime
ALIYUN_OMNI_COACH_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ALIYUN_OMNI_COACH_SILENCE_DURATION_MS=2000
ALIYUN_OMNI_BODY_AUDIO_WINDOW_MS=1200
ALIYUN_OMNI_BODY_MIN_AUDIO_PAYLOADS=3

# QA realtime interviewer
ALIYUN_QA_OMNI_MODEL=qwen3.5-omni-plus-realtime
ALIYUN_QA_OMNI_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ALIYUN_QA_OMNI_VAD_THRESHOLD=0.4
ALIYUN_QA_OMNI_MAX_TOKENS=512
ALIYUN_QA_OMNI_TEMPERATURE=0.6
ALIYUN_QA_OMNI_BOOTSTRAP_SILENCE_MS=240

# QA pacing
QA_PREWARM_INTERVAL_SECONDS=20
QA_PREWARM_TRIGGER_DELAY_MS=1500
QA_PREWARM_MIN_CHARS=120
QA_AUTO_ADVANCE_DELAY_MS=2000
QA_PARTIAL_STABILITY_ADVANCE_DELAY_MS=4500
QA_SPEECH_ACTIVE_RECHECK_MS=500
QA_SPEECH_ACTIVE_AUTO_ADVANCE_GRACE_MS=4500
QA_MIN_AUTO_ADVANCE_ZH_CHARS=4
QA_MIN_AUTO_ADVANCE_EN_WORDS=3
QA_FINISH_COMMAND_DELAY_MS=350
QA_RESPONSE_DONE_AUDIO_GRACE_MS=1200
QA_SILENCE_FALLBACK_DELAY_MS=10000
QA_PREWARM_MIN_DELTA_CHARS=40
QA_MAX_QUESTION_TOPICS=3
QA_MAX_FOLLOW_UPS_PER_QUESTION=3
ALIYUN_QA_BRAIN_TIMEOUT_SECONDS=15

# Report
REPORT_WINDOW_BUILD_INTERVAL_SECONDS=40
REPORT_WINDOW_MIN_MS=40000
ALIYUN_REPORT_WINDOW_MODEL=qwen-flash
ALIYUN_REPORT_BRAIN_MODEL=qwen-flash
ALIYUN_REPORT_BRAIN_FALLBACK_MODEL=qwen-plus-latest
ALIYUN_REPORT_WINDOW_TIMEOUT_SECONDS=30
ALIYUN_REPORT_BRAIN_TIMEOUT_SECONDS=45
ALIYUN_REPORT_WINDOW_MAX_TOKENS=1600
ALIYUN_REPORT_BRAIN_MAX_TOKENS=2600
ALIYUN_REPORT_ENABLE_THINKING=false
REPORT_REASSURANCE_AUDIO_TIMEOUT_SECONDS=12
